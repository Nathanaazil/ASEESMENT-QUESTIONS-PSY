# Copy this to .env and fill in real values. Never commit the real .env to git.

# Random secret for Flask sessions. Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# PostgreSQL connection string
# Local: postgresql://user:password@localhost:5432/assessment_db
# AWS RDS: postgresql://USER:PASS@your-db.xxxxx.region.rds.amazonaws.com:5432/assessment_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/assessment_db

# Token to access /admin/stats and /admin/export.csv
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
ADMIN_TOKEN=replace-with-a-random-token

# Port (AWS Elastic Beanstalk overrides this with 8080)
PORT=5000
